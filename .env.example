# HASAD backend environment variables (example only — never commit real values).
# ASP.NET Core reads double-underscore variables as configuration keys.

# Database (Production/Staging). Development uses appsettings.Development.json
# or the in-memory database (UseInMemoryDatabase: true).
ConnectionStrings__DefaultConnection=Host=<db-host>;Port=5432;Database=hasad_db;Username=<db-user>;Password=<db-password>

# JWT signing key: REQUIRED. Generate a random key of at least 32 characters, e.g.:
#   openssl rand -base64 48
# For local development you can instead use user secrets:
#   cd hasad/backend/Hasad.Api && dotnet user-secrets set "JwtSettings:Key" "<generated-key>"
JwtSettings__Key=<generate-with-openssl-rand-base64-48>

# Optional JWT overrides (defaults live in appsettings.json)
# JwtSettings__Issuer=HasadApi
# JwtSettings__Audience=HasadClients
# JwtSettings__AccessTokenMinutes=60
# JwtSettings__RefreshTokenDays=14

# Initial administrator (optional). When both are set, the account is created at
# startup if it does not exist. Password must satisfy the password policy
# (min 12 chars, upper, lower, digit, symbol). Remove after first login in production.
# SeedAdmin__Email=admin@example.org
# SeedAdmin__Password=<strong-password>

# Application Environment
ASPNETCORE_ENVIRONMENT=Development
