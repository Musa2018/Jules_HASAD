  },
  "AllowedHosts": "*",
  "UseInMemoryDatabase": true,
  "JwtSettings": {
    "Key": "a-very-long-and-secure-random-key-with-at-least-32-chars"
  },
  "SeedAdmin": {
    "Email": "admin@hasad.ps",
    "Password": "Str0ng!Passw0rd"
  }
}
